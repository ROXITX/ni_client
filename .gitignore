# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Flutter build outputs (project-wide)
**/build/
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies

# iOS/macOS - Pods and Flutter generated files
ios/Pods/
ios/.symlinks/
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/Flutter/App.framework
ios/Flutter/Flutter.podspec
macos/Pods/
macos/.symlinks/
macos/Flutter/ephemeral/

# Xcode user data and workspaces
ios/Runner.xcworkspace/
ios/Runner.xcodeproj/project.xcworkspace/
ios/Runner.xcodeproj/xcuserdata/
macos/Runner.xcworkspace/
macos/Runner.xcodeproj/project.xcworkspace/
macos/Runner.xcodeproj/xcuserdata/

# Android/Gradle
android/.gradle/
android/**/captures/
android/app/build/
android/build/
android/local.properties

# Gradle wrapper caches (keep wrapper files in version control)
!android/gradle/wrapper/gradle-wrapper.properties
!android/gradle/wrapper/gradle-wrapper.jar

# VS Code/JetBrains
.vscode/
# If you keep .vscode in git, comment the above and selectively include needed files
*.iml
*.ipr
*.iws
.idea/

# OS files
.DS_Store

# Logs
*.log

# Optional: Firebase config (uncomment to ignore if you don't want them in git)
# android/app/google-services.json
# ios/Runner/GoogleService-Info.plist

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
